---
interface DownloadOption {
  architecture: string;
  dividerBefore?: boolean;
  href: string;
  icon: "apple" | "windows";
  id: string;
  platform: string;
}

interface Props {
  buttonLabel: string;
  dynamicLabel?: boolean;
  macLabel?: string;
  options: DownloadOption[];
  variant?: "nav" | "hero" | "cta";
  winLabel?: string;
}

const {
  options,
  buttonLabel,
  variant = "hero",
  dynamicLabel = false,
  macLabel = buttonLabel,
  winLabel = buttonLabel,
} = Astro.props;

const menuItemClass =
  "flex items-center gap-3 px-3.5 py-2.5 text-[13px] text-text-secondary transition-colors hover:bg-surface-overlay hover:text-text-primary";
const variantClassMap = {
  nav: {
    wrapper: "relative z-40",
    button:
      "inline-flex h-8 items-center gap-1.5 rounded-lg bg-teal px-3.5 text-[13px] font-medium text-surface transition-opacity hover:opacity-90",
    menu: "absolute right-0 top-full mt-2 hidden w-56 overflow-hidden rounded-lg border border-edge bg-surface-raised shadow-xl shadow-black/40",
    chevron: "h-3 w-3 opacity-70",
    showDownloadIcon: false,
  },
  hero: {
    wrapper: "relative z-40",
    button:
      "inline-flex h-10 items-center gap-2 rounded-lg bg-teal px-5 text-[14px] font-medium text-surface transition-opacity hover:opacity-90",
    menu: "absolute left-1/2 top-full mt-2 hidden w-56 -translate-x-1/2 overflow-hidden rounded-lg border border-edge bg-surface-raised shadow-xl shadow-black/40",
    chevron: "h-3.5 w-3.5 opacity-70",
    showDownloadIcon: true,
  },
  cta: {
    wrapper: "relative mt-6 inline-block z-80",
    button:
      "inline-flex h-10 items-center gap-2 rounded-lg bg-teal px-5 text-[14px] font-medium text-surface transition-opacity hover:opacity-90",
    menu: "absolute bottom-full left-1/2 z-9999 mb-2 hidden w-56 -translate-x-1/2 overflow-hidden rounded-lg border border-edge bg-surface-raised shadow-xl shadow-black/40",
    chevron: "h-3.5 w-3.5 opacity-70",
    showDownloadIcon: true,
  },
} as const;

const variantClasses = variantClassMap[variant];

const iconMarkup = {
  apple: `<svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" /></svg>`,
  windows: `<svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12V6.75l8-1.25V12H3zm0 .5h8v6.5l-8-1.25V12.5zM11.5 5.4L21 3.75V12H11.5V5.4zm0 7.1H21v8.25l-9.5-1.65V12.5z" /></svg>`,
} as const;

const downloadIcon = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0 0l-4-4m4 4l4-4" /></svg>`;
const chevronIcon = `<svg class="${variantClasses.chevron}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>`;
---

<div class={variantClasses.wrapper} data-dropdown>
  <button
    type="button"
    class={variantClasses.button}
    data-dropdown-trigger
    aria-haspopup="true"
    aria-expanded="false"
  >
    {variantClasses.showDownloadIcon && (
      <span class="contents" set:html={downloadIcon} />
    )}
    <span
      data-download-label={dynamicLabel ? "true" : undefined}
      data-label-mac={dynamicLabel ? macLabel : undefined}
      data-label-win={dynamicLabel ? winLabel : undefined}
    >
      {buttonLabel}
    </span>
    <span class="contents" set:html={chevronIcon} />
  </button>
  <div class={variantClasses.menu} data-dropdown-menu>
    {options.map((option) => (
      <>
        {option.dividerBefore && <div class="border-edge border-t" />}
        <a class={menuItemClass} data-dl={option.id} href={option.href}>
          <span class="contents" set:html={iconMarkup[option.icon]} />
          <div>
            <div class="text-left font-medium text-text-primary">
              {option.platform}
            </div>
            <div class="text-left text-[11px] text-text-tertiary">
              {option.architecture}
            </div>
          </div>
        </a>
      </>
    ))}
  </div>
</div>
