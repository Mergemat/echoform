{
  "name": "ablegit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "bun run dev:daemon & bun run dev:client",
    "dev:client": "vite",
    "dev:daemon": "bun --watch server/src/server.ts",
    "daemon": "bun server/src/server.ts",
    "build": "tsc -b && vite build",
    "build:server:bin": "mkdir -p electron/bin && bun build --compile --target=bun --outfile electron/bin/ablegit-server server/src/server.ts",
    "app:start": "bun run build && bunx electron electron/main.mjs",
    "app:dist": "bun run build && bun run build:server:bin && bunx electron-builder --mac dir --publish never",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.bomarov.ablegit",
    "productName": "Ablegit",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "!electron/bin/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "electron/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.4",
    "recharts": "2.15.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
