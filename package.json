{
	"name": "echoform-monorepo",
	"private": true,
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --cwd apps/desktop dev",
		"dev:web": "bun run --cwd apps/web dev",
		"build": "bun run --cwd apps/desktop build",
		"build:web": "bun run --cwd apps/web build",
		"test": "bun run --cwd apps/desktop test",
		"lint": "bun run --cwd apps/desktop lint",
		"typecheck": "bun run --cwd apps/desktop typecheck",
		"check": "bun run --cwd apps/desktop check"
	}
}
